# Application
APP_NAME="LMS Misdinar"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost

# Reverse Proxy
# Set trusted proxy IP/CIDR list in production, e.g. 127.0.0.1,::1
# Use * only for local development/testing.
TRUSTED_PROXIES=

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lms_misdinar
DB_USERNAME=root
DB_PASSWORD=

# Session & Cache
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file

# Queue
QUEUE_CONNECTION=database

# Mail (optional)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@localhost"
MAIL_FROM_NAME="${APP_NAME}"

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Vite
VITE_APP_NAME="${APP_NAME}"
