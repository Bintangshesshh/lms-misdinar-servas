# Application
APP_NAME="LMS Misdinar"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost

# Reverse Proxy
# Set trusted proxy IP/CIDR list in production, e.g. 127.0.0.1,::1
# Use * only for local development/testing.
TRUSTED_PROXIES=

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lms_misdinar
DB_USERNAME=root
DB_PASSWORD=

# Session & Cache
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file

# Queue
QUEUE_CONNECTION=database

# Mail (optional)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@localhost"
MAIL_FROM_NAME="${APP_NAME}"

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# No-SSH Deploy Helper (one-time cache warm endpoint)
DEPLOY_CACHE_WARM_ENABLED=false
DEPLOY_CACHE_WARM_TOKEN=
DEPLOY_CACHE_WARM_ALLOW_GET=true
DEPLOY_CACHE_WARM_INCLUDE_ROUTE=false

# Exam Runtime Tuning
# normal | crowded
EXAM_LOAD_PROFILE=normal
EXAM_MIN_POLL_MS=5000

# Optional explicit overrides (milliseconds)
# EXAM_STUDENT_POLL_BASE_MS=15000
# EXAM_STUDENT_POLL_JITTER_MS=5000
# EXAM_ADMIN_POLL_LOBBY_MS=5000
# EXAM_ADMIN_POLL_COUNTDOWN_MS=5000
# EXAM_ADMIN_POLL_RUNNING_SMALL_MS=5000
# EXAM_ADMIN_POLL_RUNNING_MEDIUM_MS=7000
# EXAM_ADMIN_POLL_RUNNING_LARGE_MS=9000
# EXAM_ADMIN_POLL_FINISHED_MS=20000
# EXAM_ADMIN_AUTO_PAUSE_FINISHED=0
# EXAM_ADMIN_FINISHED_STABLE_ROUNDS=5
# EXAM_ADMIN_FINISHED_HEARTBEAT_MS=90000

# Vite
VITE_APP_NAME="${APP_NAME}"
