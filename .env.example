# Application Configuration
APP_NAME="LMS Misdinar"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lms_misdinar
DB_USERNAME=root
DB_PASSWORD=

# Session Configuration - IMPORTANT FOR SCALABILITY
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Cache Configuration - IMPORTANT FOR PERFORMANCE
CACHE_STORE=database
CACHE_PREFIX=lms_cache

# Queue Configuration - IMPORTANT FOR BACKGROUND JOBS
QUEUE_CONNECTION=database

# Mail Configuration (Optional)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@lmsmisdinar.local"
MAIL_FROM_NAME="${APP_NAME}"

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Broadcasting (Optional - for WebSocket if needed)
BROADCAST_CONNECTION=log
BROADCAST_DRIVER=log

# Vite Configuration
VITE_APP_NAME="${APP_NAME}"

# Security & Performance Settings
# ==================================
# Rate Limiting: Protects against abuse
# Session: database driver for multi-server support
# Cache: Enable for better performance

# RECOMMENDED PRODUCTION SETTINGS:
# SESSION_DRIVER=database (or redis for better performance)
# CACHE_STORE=redis (or database if Redis not available)
# QUEUE_CONNECTION=database (or redis)

# For 100+ concurrent users, consider:
# - Redis for session/cache (install: composer require predis/predis)
# - Queue workers: php artisan queue:work --tries=3 --timeout=60
# - Database connection pooling
# - Server: Min 2GB RAM, 2 CPU cores

# Optional: Redis Configuration (Recommended for 100+ users)
# REDIS_CLIENT=predis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1
