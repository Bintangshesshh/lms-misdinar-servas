APP_NAME="LMS Misdinar"
APP_ENV=production
APP_KEY=base64:ISI_APP_KEY_PRODUCTION_DI_SINI
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://misdinarservas.cloud

# Reverse proxy (kosongkan jika tidak pakai)
# Contoh: 127.0.0.1,::1
TRUSTED_PROXIES=

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u834752486_lms_misdinar
DB_USERNAME=u834752486_misdinar
DB_PASSWORD=ISI_PASSWORD_DB_PRODUCTION

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=

CACHE_STORE=database
QUEUE_CONNECTION=sync

LOG_CHANNEL=stack
LOG_LEVEL=warning

# No-SSH Deploy Helper (one-time cache warm endpoint)
DEPLOY_CACHE_WARM_ENABLED=false
DEPLOY_CACHE_WARM_TOKEN=GANTI_DENGAN_TOKEN_ACAK_PANJANG_MIN_32_CHAR
DEPLOY_CACHE_WARM_ALLOW_GET=true
DEPLOY_CACHE_WARM_INCLUDE_ROUTE=false

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@misdinarservas.cloud"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Exam Runtime Tuning (recommended for 100 participants on shared hosting)
EXAM_LOAD_PROFILE=crowded
EXAM_MIN_POLL_MS=5000
EXAM_STUDENT_POLL_BASE_MS=18000
EXAM_STUDENT_POLL_JITTER_MS=6000
EXAM_ADMIN_POLL_LOBBY_MS=6000
EXAM_ADMIN_POLL_COUNTDOWN_MS=6000
EXAM_ADMIN_POLL_RUNNING_SMALL_MS=7000
EXAM_ADMIN_POLL_RUNNING_MEDIUM_MS=9000
EXAM_ADMIN_POLL_RUNNING_LARGE_MS=12000
EXAM_ADMIN_POLL_FINISHED_MS=30000
EXAM_ADMIN_POLL_JITTER_MS=1500
EXAM_ADMIN_AUTO_PAUSE_FINISHED=1
EXAM_ADMIN_FINISHED_STABLE_ROUNDS=5
EXAM_ADMIN_FINISHED_HEARTBEAT_MS=120000
