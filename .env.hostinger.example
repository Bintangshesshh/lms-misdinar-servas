APP_NAME="LMS Misdinar"
APP_ENV=production
APP_KEY=base64:ISI_APP_KEY_PRODUCTION_DI_SINI
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://misdinarservas.cloud

# Reverse proxy (kosongkan jika tidak pakai)
# Contoh: 127.0.0.1,::1
TRUSTED_PROXIES=

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u834752486_lms_misdinar
DB_USERNAME=u834752486_misdinar
DB_PASSWORD=ISI_PASSWORD_DB_PRODUCTION

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=

CACHE_STORE=database
QUEUE_CONNECTION=sync

LOG_CHANNEL=stack
LOG_LEVEL=warning

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@misdinarservas.cloud"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
